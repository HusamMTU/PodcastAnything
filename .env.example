# AWS credentials for local CLI runs (do not commit real secrets)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# AWS region
AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# Required pipeline settings
MP_BUCKET=your-unique-s3-bucket-name
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# TTS provider selection: polly | elevenlabs
TTS_PROVIDER=polly

# Polly settings (used when TTS_PROVIDER=polly)
POLLY_VOICE_ID=Joanna

# ElevenLabs settings (ELEVENLABS_API_KEY required when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optional local script/API overrides
STACK_NAME=PodcastAnythingStack
# PIPELINE_API_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com
# PIPELINE_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:PipelineStateMachine
